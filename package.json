{
  "name": "camber",
  "private": true,
  "version": "0.0.0",
  "description": "Constant-camber boat-hull line drawing tool",
  "type": "module",
  "scripts": {
    "build": "esbuild src/main.ts --bundle --format=esm --outfile=dist/camber.js --sourcemap && esbuild src/files.ts --bundle --format=esm --outfile=dist/files.js --sourcemap && esbuild src/interp.ts --bundle --format=esm --outfile=dist/interpolate.js --sourcemap",
    "dev": "esbuild camber=src/main.ts files=src/files.ts interpolate=src/interp.ts --bundle --format=esm --sourcemap --outdir=dist --servedir=. --serve=127.0.0.1:8000 --watch --banner:js=\"new EventSource('/esbuild').addEventListener('change', () => location.reload())\"",
    "watch": "esbuild src/main.ts --bundle --format=esm --outfile=dist/camber.js --sourcemap --watch",
    "watch:files": "esbuild src/files.ts --bundle --format=esm --outfile=dist/files.js --sourcemap --watch",
    "watch:interp": "esbuild src/interp.ts --bundle --format=esm --outfile=dist/interpolate.js --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "test:smooth": "esbuild test/smoothness.ts --bundle --platform=node --format=esm --outfile=dist/smoothness.mjs && node dist/smoothness.mjs",
    "test:centerline": "esbuild test/centerline.ts --bundle --platform=node --format=esm --outfile=dist/centerline.mjs && node dist/centerline.mjs",
    "test": "npm run test:smooth && npm run test:centerline"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
