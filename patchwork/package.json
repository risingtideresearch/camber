{
  "name": "@camber/patchwork-hull",
  "private": true,
  "version": "0.0.0",
  "description": "Camber constant-camber hull editor as a Patchwork tool + datatype",
  "type": "module",
  "exports": "./dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --sourcemap",
    "watch": "esbuild src/index.ts --bundle --format=esm --outfile=dist/index.js --sourcemap --watch",
    "typecheck": "tsc --noEmit",
    "push": "npm run build && pushwork sync",
    "register": "pw-modules add \"$MODULE_SETTINGS_DOC_URL\" \"$(pushwork url)\""
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
